# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/demo-licenses?retryWrites=true&w=majority

# OCR.space API key — https://ocr.space/ocrapi (free tier: 25,000 req/month)
OCR_SPACE_API_KEY=helloworld

# ImageKit — https://imagekit.io (free tier: 20GB storage, 20GB bandwidth/month)
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# CORS — comma-separated allowed origins (* = all)
ALLOWED_ORIGINS=*
